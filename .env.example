# =============================================================================
# Oxmux — Environment Configuration
# Copy to .env and fill in values. Never commit .env.
# In production all values are stored in Kubernetes Secret/ConfigMap.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
OXMUX_HOST=0.0.0.0
OXMUX_PORT=8080
OXMUX_LOG_LEVEL=info
# Secret for signing session JWTs (generate: openssl rand -hex 32)
OXMUX_JWT_SECRET=changeme

# -----------------------------------------------------------------------------
# QUIC Transport (server ↔ agent)
# TLS cert/key for QUIC listener (can reuse the same certs as HTTPS)
# -----------------------------------------------------------------------------
QUIC_LISTEN_PORT=4433
QUIC_CERT_PATH=/etc/oxmux/tls/fullchain.pem
QUIC_KEY_PATH=/etc/oxmux/tls/key.pem

# -----------------------------------------------------------------------------
# COTURN — WebRTC TURN relay
# Shared secret auth (HMAC-SHA1 time-limited credentials)
# See: https://github.com/gjovanov/k8s-cluster-multi
# -----------------------------------------------------------------------------
COTURN_AUTH_SECRET=your_coturn_shared_secret_here
COTURN_REALM=coturn.roomler.live
COTURN_TTL=86400

# COTURN servers (3 instances — one per Hetzner worker)
# Format: host:port (TURN) or host:tls_port (TURNS)
COTURN_SERVERS=198.51.100.10:3478,198.51.100.20:3478,198.51.100.30:3478
COTURN_TLS_SERVERS=198.51.100.10:5349,198.51.100.20:5349,198.51.100.30:5349

# -----------------------------------------------------------------------------
# SSH Defaults (per-host overrides stored in DB)
# -----------------------------------------------------------------------------
SSH_DEFAULT_PORT=22
SSH_DEFAULT_USER=deployer
SSH_CONNECT_TIMEOUT_SECS=10
SSH_KEEPALIVE_INTERVAL_SECS=30

# -----------------------------------------------------------------------------
# oxmux-agent QUIC
# -----------------------------------------------------------------------------
AGENT_QUIC_PORT=4433
# Fingerprint of agent's self-signed cert (skip TLS verify in dev: true)
AGENT_TLS_SKIP_VERIFY=false

# -----------------------------------------------------------------------------
# Claude Code
# -----------------------------------------------------------------------------
# Optional: default flags passed to claude on remote sessions
CLAUDE_DEFAULT_FLAGS=--output-format stream-json
# Cost alert threshold USD (0 = disabled)
CLAUDE_COST_ALERT_USD=1.00
# Context window warning threshold (0.0 - 1.0)
CLAUDE_CONTEXT_WARN_THRESHOLD=0.80

# -----------------------------------------------------------------------------
# Database (SQLite in dev, Postgres in prod)
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:./oxmux.db
# DATABASE_URL=postgres://oxmux:password@localhost:5432/oxmux

# -----------------------------------------------------------------------------
# Frontend (injected at Vite build time via VITE_ prefix)
# -----------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
